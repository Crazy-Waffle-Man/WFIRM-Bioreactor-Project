{
    "$schema": "./schema.json",
    "cycle": [
        {
            "action": "multiple",
            "actions": [
                {
                    "action": "pressurize",
                    "pressure": 30,
                    "check_every": 500,
                    "duration": 100000
                },
                {
                    "action": "wait",
                    "duration": 10000
                }
            ]
        },
        {
            "action": "multiple",
            "actions": [
                {
                    "action": "pressurize",
                    "pressure": 0,
                    "check_every": 500,
                    "duration": 100000
                },
                {
                    "action": "wait",
                    "duration": 10000
                }
            ]
        }
    ]
}